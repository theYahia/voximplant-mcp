# Voximplant Platform API credentials (manage.voximplant.com → раздел API)
# В проде эти переменные передаёт MCP-хост (Claude Desktop / Code) через env.
# Для локальной разработки скопируйте в .env — config.ts подхватит его (loadDotenv).
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=

# Опционально: порт для HTTP-режима (--http), по умолчанию 3000
# PORT=3000
