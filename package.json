{
  "name": "@theyahia/voximplant-mcp",
  "version": "1.1.0",
  "description": "MCP server for Voximplant — cloud telephony, call history, SMS (Russia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "voximplant-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/voximplant-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "voximplant",
    "telephony",
    "sms",
    "api",
    "typescript",
    "voice",
    "cpaas"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/voximplant-mcp.git"
  },
  "homepage": "https://github.com/theYahia/voximplant-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
